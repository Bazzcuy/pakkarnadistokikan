<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_screen" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp" android:gravity="center_horizontal">
        <ImageView android:layout_width="match_parent" android:layout_height="260dp" android:src="@drawable/catokan_banner" android:scaleType="centerCrop" android:contentDescription="Banner CATOKAN" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp" android:layout_marginTop="16dp" android:background="@drawable/bg_card">
            <TextView style="@style/CatokanTitle" android:text="Kelola stok ikan tanpa ribet" />
            <TextView style="@style/CatokanSubtitle" android:text="CATOKAN membantu mencatat stok mentah, produksi giling, transaksi penjualan, dan laporan ringkas secara lokal/offline." android:layout_marginTop="6dp" />
            <TextView style="@style/CatokanLabel" android:text="Fitur unggulan" android:layout_marginTop="10dp" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="• Dashboard cepat
• Input stok dan produksi
• Penjualan cepat
• Role Admin, Kasir, Operator
• SQLite lokal tanpa internet" android:textColor="@color/catokan_text" android:textSize="14sp" android:lineSpacingExtra="4dp" />
            <Button android:id="@+id/btnStart" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="18dp" android:background="@drawable/bg_primary_btn" android:text="Mulai Pakai CATOKAN" android:textAllCaps="false" android:textColor="@color/white" android:textStyle="bold" />
            <Button android:id="@+id/btnSkip" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_secondary_btn" android:text="Lewati ke Login" android:textAllCaps="false" android:textColor="@color/catokan_primary_dark" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
