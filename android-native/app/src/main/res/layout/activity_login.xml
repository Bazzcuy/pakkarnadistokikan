<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:background="@drawable/bg_screen">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <ImageView android:id="@+id/imgBanner" android:layout_width="match_parent" android:layout_height="190dp" android:scaleType="centerCrop" android:src="@drawable/catokan_banner" android:contentDescription="Banner CATOKAN" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="center_vertical" android:padding="16dp" android:layout_marginTop="14dp" android:background="@drawable/bg_card">
            <ImageView android:layout_width="76dp" android:layout_height="76dp" android:src="@drawable/catokan_logo" android:contentDescription="Logo CATOKAN" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:paddingLeft="14dp" android:orientation="vertical">
                <TextView style="@style/CatokanTitle" android:text="CATOKAN" />
                <TextView style="@style/CatokanSubtitle" android:text="Catat Stok Ikan" />
            </LinearLayout>
        </LinearLayout>
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="18dp" android:layout_marginTop="14dp" android:background="@drawable/bg_card">
            <TextView style="@style/CatokanTitle" android:text="Masuk ke Dashboard" />
            <TextView style="@style/CatokanSubtitle" android:text="Kelola stok ikan dengan tampilan yang bersih, cepat, dan nyaman dipakai di HP." android:layout_marginTop="4dp" />
            <TextView style="@style/CatokanLabel" android:text="Akun Awal" />
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_text_panel" android:padding="12dp" android:text="Pengguna : pengguna / pengguna123&#10;Akun awal ini membuka semua fitur stok, produksi, penjualan, dan laporan." android:textColor="@color/catokan_text" android:textSize="13sp" />
            <TextView style="@style/CatokanLabel" android:text="Username" />
            <EditText android:id="@+id/edtUsername" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_input" android:padding="14dp" android:singleLine="true" android:hint="pengguna" />
            <TextView style="@style/CatokanLabel" android:text="Password" />
            <EditText android:id="@+id/edtPassword" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_input" android:padding="14dp" android:singleLine="true" android:inputType="textPassword" android:hint="pengguna123" />
            <Button android:id="@+id/btnLogin" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:background="@drawable/bg_primary_btn" android:text="Masuk" android:textAllCaps="false" android:textColor="@color/white" android:textStyle="bold" />
            <TextView style="@style/CatokanLabel" android:text="Masuk Cepat" android:layout_marginTop="8dp" />
            <Button android:id="@+id/btnAdmin" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_secondary_btn" android:text="Login sebagai Pengguna" android:textAllCaps="false" android:textColor="@color/catokan_primary_dark" android:textStyle="bold" />
            <Button android:id="@+id/btnKasir" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_secondary_btn" android:text="Isi Akun Awal" android:textAllCaps="false" android:textColor="@color/catokan_primary_dark" android:textStyle="bold" />
            <Button android:id="@+id/btnOperator" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:background="@drawable/bg_secondary_btn" android:text="Daftar Akun Pengguna" android:textAllCaps="false" android:textColor="@color/catokan_primary_dark" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
