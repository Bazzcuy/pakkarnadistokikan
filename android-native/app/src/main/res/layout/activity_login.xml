<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:src="@drawable/catokan_banner"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-22dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:background="@drawable/bg_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="82dp"
                    android:layout_height="82dp"
                    android:src="@drawable/catokan_logo"
                    android:scaleType="fitCenter" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingLeft="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CATOKAN"
                        android:textColor="@color/catokan_text"
                        android:textSize="27sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Catat Stok Ikan"
                        android:textColor="@color/catokan_muted"
                        android:textSize="16sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Masuk ke Akun Anda"
                android:textColor="@color/catokan_text"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Silakan login untuk membuka dashboard stok, produksi, transaksi, dan laporan."
                android:textColor="@color/catokan_muted"
                android:textSize="14sp"
                android:lineSpacingExtra="2dp" />

            <TextView style="@style/CatokanLabel" android:text="Username" />
            <EditText
                android:id="@+id/edtUsername"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:singleLine="true"
                android:hint="Masukkan username" />

            <TextView style="@style/CatokanLabel" android:text="Password" />
            <EditText
                android:id="@+id/edtPassword"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:background="@drawable/bg_input"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:singleLine="true"
                android:inputType="textPassword"
                android:hint="Masukkan password" />

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:background="@drawable/bg_primary_btn"
                android:text="Masuk"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Atau login cepat"
                android:textColor="@color/catokan_muted"
                android:textSize="13sp"
                android:gravity="center" />

            <Button
                android:id="@+id/btnAdmin"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_secondary_btn"
                android:text="Login sebagai Pengguna"
                android:textAllCaps="false"
                android:textColor="@color/catokan_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnKasir"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_secondary_btn"
                android:text="Isi Akun Awal"
                android:textAllCaps="false"
                android:textColor="@color/catokan_primary"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnOperator"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_secondary_btn"
                android:text="Daftar Akun Pengguna"
                android:textAllCaps="false"
                android:textColor="@color/catokan_primary"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
