<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="match_parent" android:background="@drawable/bg_screen" android:fillViewport="true">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="18dp" android:orientation="vertical" android:background="@drawable/bg_gradient_card">
            <TextView android:id="@+id/txtTitle" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Data" android:textColor="@color/white" android:textSize="23sp" android:textStyle="bold"/>
            <TextView android:id="@+id/txtSubtitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Ringkasan data operasional CATOKAN." android:textColor="#DFF7FF" android:textSize="14sp" android:layout_marginTop="5dp"/>
        </LinearLayout>
        <TextView android:id="@+id/txtContent" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_text_panel" android:fontFamily="monospace" android:padding="16dp" android:textColor="@color/catokan_text" android:textIsSelectable="true" android:textSize="13sp" android:lineSpacingExtra="3dp"/>
        <Button android:id="@+id/btnBack" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:background="@drawable/bg_secondary_btn" android:text="Kembali" android:textAllCaps="false" android:textColor="@color/catokan_primary_dark" android:textStyle="bold"/>
    </LinearLayout>
</ScrollView>
