<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:gravity="center" android:padding="28dp"
    android:background="@drawable/bg_screen">
    <ImageView android:id="@+id/imgLogo" android:layout_width="150dp" android:layout_height="150dp" android:src="@drawable/catokan_logo" android:contentDescription="Logo CATOKAN" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CATOKAN" android:textColor="@color/catokan_text" android:textSize="34sp" android:textStyle="bold" android:layout_marginTop="18dp" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Catat Stok Ikan" android:textColor="@color/catokan_muted" android:textSize="16sp" android:layout_marginTop="4dp" />
    <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Stok • Produksi • Transaksi" android:gravity="center" android:textColor="@color/catokan_primary_dark" android:textStyle="bold" android:layout_marginTop="24dp" />
</LinearLayout>
