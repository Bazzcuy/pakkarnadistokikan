<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_screen">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="230dp"
            android:background="@drawable/bg_gradient_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="18dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/bg_logo_plate"
                        android:padding="5dp"
                        android:src="@drawable/catokan_logo"
                        android:scaleType="fitCenter" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:paddingLeft="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="CATOKAN"
                            android:textColor="@color/white"
                            android:textSize="30sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtGreeting"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Halo, Pengguna"
                            android:textColor="#E9FBFF"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:text="Kelola stok ikan dengan mudah, produksi, transaksi, dan laporan dengan cepat."
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:lineSpacingExtra="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/txtRole"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:background="@drawable/bg_role_chip"
                        android:text="Login: Pengguna"
                        android:textColor="@color/catokan_primary_dark"
                        android:textStyle="bold" />

                    <Space android:layout_width="10dp" android:layout_height="1dp" />

                    <Button
                        android:id="@+id/btnProfile"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_primary_btn"
                        android:text="Akun &amp; Profil"
                        android:textAllCaps="false"
                        android:textColor="@color/white"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:padding="18dp"
            android:background="@drawable/bg_card">

            <TextView style="@style/CatokanTitle" android:text="Shortcut Aktivitas" />
            <TextView android:id="@+id/txtWorkspace" style="@style/CatokanSubtitle" android:text="Akses cepat ke fitur utama" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="14dp">

                <Button android:id="@+id/btnWorkspaceAdmin" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:background="@drawable/bg_bottom_item" android:drawableTop="@drawable/ic_box" android:text="Stok" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
                <Space android:layout_width="10dp" android:layout_height="1dp" />
                <Button android:id="@+id/btnWorkspaceProduction" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:background="@drawable/bg_bottom_item" android:drawableTop="@drawable/ic_fish" android:text="Produksi" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
                <Space android:layout_width="10dp" android:layout_height="1dp" />
                <Button android:id="@+id/btnWorkspaceCashier" android:layout_width="0dp" android:layout_height="72dp" android:layout_weight="1" android:background="@drawable/bg_bottom_item" android:drawableTop="@drawable/ic_sales" android:text="Jual" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="14dp">
            <LinearLayout android:layout_width="0dp" android:layout_height="108dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center_vertical" android:padding="16dp" android:background="@drawable/bg_stat_teal">
                <TextView android:text="Stok Mentah" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/catokan_muted" android:textSize="13sp" />
                <TextView android:id="@+id/txtStokMentah" android:text="-- kg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/catokan_text" android:textSize="23sp" android:textStyle="bold" />
            </LinearLayout>
            <Space android:layout_width="12dp" android:layout_height="1dp" />
            <LinearLayout android:layout_width="0dp" android:layout_height="108dp" android:layout_weight="1" android:orientation="vertical" android:gravity="center_vertical" android:padding="16dp" android:background="@drawable/bg_stat_blue">
                <TextView android:text="Stok Giling" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/catokan_muted" android:textSize="13sp" />
                <TextView android:id="@+id/txtStokGiling" android:text="-- kg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/catokan_text" android:textSize="23sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="100dp" android:orientation="vertical" android:gravity="center_vertical" android:padding="16dp" android:layout_marginTop="12dp" android:background="@drawable/bg_stat_orange">
            <TextView android:text="Total Penjualan" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/catokan_muted" android:textSize="13sp" />
            <TextView android:id="@+id/txtTotalJual" android:text="Rp --" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/catokan_text" android:textSize="23sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="100dp" android:orientation="vertical" android:gravity="center_vertical" android:padding="16dp" android:layout_marginTop="12dp" android:background="@drawable/bg_stat_teal">
            <TextView android:text="Stok Perlu Dijual Dulu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/catokan_muted" android:textSize="13sp" />
            <TextView android:id="@+id/txtStokLama" android:text="-- kg" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="@color/catokan_text" android:textSize="23sp" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:orientation="vertical" android:padding="18dp" android:background="@drawable/bg_card">
            <TextView style="@style/CatokanTitle" android:text="Menu Utama" />
            <TextView style="@style/CatokanSubtitle" android:text="Semua fitur ada dalam satu dashboard pengguna." />
            <Button android:id="@+id/btnFishMaster" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="12dp" android:background="@drawable/bg_menu_btn" android:drawableStart="@drawable/ic_fish" android:drawablePadding="14dp" android:gravity="center_vertical|left" android:paddingLeft="16dp" android:text="Data Kelola Jenis Ikan" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            <Button android:id="@+id/btnSupplier" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="8dp" android:background="@drawable/bg_menu_btn" android:drawableStart="@drawable/ic_box" android:drawablePadding="14dp" android:gravity="center_vertical|left" android:paddingLeft="16dp" android:text="Data Supplier" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            <Button android:id="@+id/btnCustomer" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="8dp" android:background="@drawable/bg_menu_btn" android:drawableStart="@drawable/ic_sales" android:drawablePadding="14dp" android:gravity="center_vertical|left" android:paddingLeft="16dp" android:text="Data Pelanggan" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            <Button android:id="@+id/btnRawInput" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="8dp" android:background="@drawable/bg_menu_btn" android:drawableStart="@drawable/ic_stock_in" android:drawablePadding="14dp" android:gravity="center_vertical|left" android:paddingLeft="16dp" android:text="Input Stok Ikan Mentah" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            <Button android:id="@+id/btnProduction" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="8dp" android:background="@drawable/bg_menu_btn" android:drawableStart="@drawable/ic_production" android:drawablePadding="14dp" android:gravity="center_vertical|left" android:paddingLeft="16dp" android:text="Proses Produksi Giling" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            <Button android:id="@+id/btnRawStock" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="8dp" android:background="@drawable/bg_menu_btn" android:drawableStart="@drawable/ic_box" android:drawablePadding="14dp" android:gravity="center_vertical|left" android:paddingLeft="16dp" android:text="Lihat Stok Mentah" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            <Button android:id="@+id/btnGilingStock" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="8dp" android:background="@drawable/bg_menu_btn" android:drawableStart="@drawable/ic_fish" android:drawablePadding="14dp" android:gravity="center_vertical|left" android:paddingLeft="16dp" android:text="Lihat Stok Giling" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            <Button android:id="@+id/btnSales" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="8dp" android:background="@drawable/bg_menu_btn" android:drawableStart="@drawable/ic_sales" android:drawablePadding="14dp" android:gravity="center_vertical|left" android:paddingLeft="16dp" android:text="Penjualan Cepat" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            <Button android:id="@+id/btnStockControl" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="8dp" android:background="@drawable/bg_menu_btn" android:drawableStart="@drawable/ic_stock_in" android:drawablePadding="14dp" android:gravity="center_vertical|left" android:paddingLeft="16dp" android:text="Cek &amp; Perbaiki Stok" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            <Button android:id="@+id/btnReport" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="8dp" android:background="@drawable/bg_menu_btn" android:drawableStart="@drawable/ic_report" android:drawablePadding="14dp" android:gravity="center_vertical|left" android:paddingLeft="16dp" android:text="Laporan Ringkas" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            <Button android:id="@+id/btnTransferData" android:layout_width="match_parent" android:layout_height="58dp" android:layout_marginTop="8dp" android:background="@drawable/bg_menu_btn" android:drawableStart="@drawable/ic_report" android:drawablePadding="14dp" android:gravity="center_vertical|left" android:paddingLeft="16dp" android:text="Cadangkan / Pulihkan Data" android:textAllCaps="false" android:textColor="@color/catokan_text" android:textStyle="bold" />
            <Button android:id="@+id/btnLogout" android:layout_width="match_parent" android:layout_height="54dp" android:layout_marginTop="14dp" android:background="@drawable/bg_secondary_btn" android:text="Logout" android:textAllCaps="false" android:textColor="@color/catokan_primary" android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="70dp" android:layout_marginTop="14dp" android:layout_marginBottom="12dp" android:orientation="horizontal" android:padding="8dp" android:background="@drawable/bg_card">
            <Button android:id="@+id/btnBottomHome" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_bottom_active" android:drawableTop="@drawable/ic_home" android:text="Home" android:textAllCaps="false" android:textColor="@color/catokan_primary" />
            <Button android:id="@+id/btnBottomStock" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_bottom_item" android:drawableTop="@drawable/ic_fish" android:text="Stok" android:textAllCaps="false" android:textColor="@color/catokan_muted" />
            <Button android:id="@+id/btnBottomReport" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/bg_bottom_item" android:drawableTop="@drawable/ic_report" android:text="Laporan" android:textAllCaps="false" android:textColor="@color/catokan_muted" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
